const fs   = require("fs");
const path = require("path");

module.exports.config = {
  name: "نظام_وايد",
  version: "2.0.1",
  hasPermssion: 2,
  credits: "ليفاي",
  description: "لوحة تحكم WAYED — إدارة كاملة للبوت من الشات",
  commandCategory: "المطور",
  usages: "",
  cooldowns: 0
};

const DEV_IDS = ["61583632364472", "100081948980908"];
const CMDS_PATH = __dirname;
const EVNT_PATH = path.join(__dirname, "..", "events");
const D = "────────────────────";

function isAdmin(id) {
  if (DEV_IDS.includes(String(id))) return true;
  return ((global.config && global.config.ADMINBOT) || []).includes(String(id));
}

function listJS(dir) {
  try { return fs.readdirSync(dir).filter(f => f.endsWith(".js")).sort(); }
  catch(e) { return []; }
}

function readSafe(fp) {
  try {
    const c = fs.readFileSync(fp, "utf8");
    return c.length > 3500 ? c.slice(0, 3500) + "\n\n…[مقطوع]" : c;
  } catch(e) { return null; }
}

function hotReload(fp) {
  try {
    delete require.cache[require.resolve(fp)];
    const mod = require(fp);
    if (mod.config && mod.config.name) {
      global.client.commands.set(mod.config.name.toLowerCase(), mod);
      return `⚡ تم تحميل ${mod.config.name}`;
    }
    return "⚠️ تم الحفظ فقط";
  } catch(e) {
    return `❌ خطأ: ${e.message}`;
  }
}

function resolvePath(name) {
  let fp = path.join(CMDS_PATH, name);
  if (!fs.existsSync(fp)) fp = path.join(EVNT_PATH, name);
  return fs.existsSync(fp) ? fp : null;
}

// القائمة
const MENU = `
───═━━━━━
⏤͟͟͞͞   WAYED SYSTEM
────────
⑉ تعديل
⑉ ملفات
⑉ اضافة
⑉ حذف
⑉ كود
────────
`;

// التشغيل
module.exports.run = async function ({ api, event, args }) {
  const { threadID, messageID, senderID } = event;

  if (!isAdmin(senderID)) 
    return api.sendMessage("🚫 هذا الأمر للمطور فقط", threadID, messageID);

  const sub = (args[0] || "").toLowerCase();

  // القائمة
  if (!sub) return api.sendMessage(MENU, threadID, messageID);

  // الملفات
  if (sub === "ملفات") {
    const files = listJS(CMDS_PATH);
    return api.sendMessage(files.join("\n"), threadID, messageID);
  }

  // تعديل
  if (sub === "تعديل") {
    const fileName = args[1];
    if (!fileName) return api.sendMessage("اكتب اسم الملف", threadID, messageID);

    const fp = resolvePath(fileName);
    if (!fp) return api.sendMessage("❌ غير موجود", threadID, messageID);

    const content = readSafe(fp);
    return api.sendMessage(
      content + "\n\n✏️ رد بالكود الجديد",
      threadID,
      (err, info) => {
        global.client.handleReply.push({
          name: this.config.name,
          author: senderID,
          messageID: info.messageID,
          type: "edit",
          path: fp
        });
      },
      messageID
    );
  }

  // اضافة
  if (sub === "اضافة") {
    const name = args[1];
    if (!name) return api.sendMessage("اكتب اسم الامر", threadID, messageID);

    const filePath = path.join(CMDS_PATH, name + ".js");

    fs.writeFileSync(filePath, `
module.exports.config = {
  name: "${name}",
  version: "1.0.0",
  hasPermssion: 0,
  credits: "WAYED",
  description: "امر جديد",
  commandCategory: "عام",
  usages: "",
  cooldowns: 3
};

module.exports.run = async function({ api, event }) {
  api.sendMessage("تم تشغيل الامر", event.threadID);
};
`);

    const msg = hotReload(filePath);
    return api.sendMessage("✅ تم الانشاء\n" + msg, threadID, messageID);
  }

  // حذف
  if (sub === "حذف") {
    const name = args[1];
    if (!name) return api.sendMessage("اكتب الاسم", threadID, messageID);

    const filePath = path.join(CMDS_PATH, name + ".js");
    if (!fs.existsSync(filePath)) return api.sendMessage("❌ غير موجود", threadID, messageID);

    fs.unlinkSync(filePath);
    global.client.commands.delete(name.toLowerCase());

    return api.sendMessage("🗑️ تم الحذف", threadID, messageID);
  }

  // كود
  if (sub === "كود") {
    const code = args.slice(1).join(" ");
    try {
      let result = eval(code);
      if (result instanceof Promise) result = await result;
      return api.sendMessage(String(result), threadID, messageID);
    } catch (e) {
      return api.sendMessage("❌ " + e.message, threadID, messageID);
    }
  }

  return api.sendMessage("❓ خيار غير معروف", threadID, messageID);
};

// الردود
module.exports.handleReply = async function ({ api, event, handleReply }) {
  const { body, threadID, messageID, senderID } = event;
  if (senderID != handleReply.author) return;

  if (handleReply.type === "edit") {
    try {
      fs.writeFileSync(handleReply.path, body);
      const msg = hotReload(handleReply.path);
      return api.sendMessage("✅ تم التعديل\n" + msg, threadID, messageID);
    } catch (e) {
      return api.sendMessage("❌ " + e.message, threadID, messageID);
    }
  }
};
