const fs = require("fs-extra");
const path = require("path");

module.exports.config = {
  name: "نظام_وايد",
  version: "2.1.0",
  hasPermssion: 2,
  credits: "ليفاي & حمودي سان",
  description: "لوحة تحكم إدارة الملفات والأوامر",
  commandCategory: "المطور",
  usages: "[تعديل/ملفات/اضافة/حذف/كود]",
  cooldowns: 0
};

// ── إعدادات المسارات ──
const CMDS_PATH = path.join(__dirname);
const D = "────────";

// ── القائمة الرئيسية بالزخرفة المطلوبة ──
const MENU = 
`───═━━━━━
⏤͟͟͞͞   𝙽𝙸𝚉𝙰𝙼  𝚆𝙰𝚈𝙴𝙳
────────
⑉ تعديل
⑉ ملفات
⑉ اضافة
⑉ حذف
⑉ كود
────────
.𝚂𝚃𝙰𝚃𝚄𝚂 : 𝙾𝙽𝙻𝙸𝙽𝙴
.𝙿𝚁𝙴𝙵𝙸𝚇 : /
────────`;

// ── دالة التحقق من المطور ──
function isAdmin(id) {
  const DEV_IDS = ["61583632364472", "100081948980908"];
  return DEV_IDS.includes(String(id)) || (global.config.ADMINBOT || []).includes(String(id));
}

module.exports.run = async function ({ api, event, args }) {
  const { threadID, messageID, senderID } = event;
  if (!isAdmin(senderID)) return api.sendMessage("⚠️ عذراً، هذا الأمر مخصص لمطوري البوت فقط.", threadID, messageID);

  const sub = (args[0] || "").trim();

  if (!sub) return api.sendMessage(MENU, threadID, messageID);

  // ── قسم تعديل ملف ──
  if (sub === "تعديل") {
    const fileName = args.slice(1).join(" ").trim();
    if (!fileName) {
      const files = fs.readdirSync(CMDS_PATH).filter(f => f.endsWith(".js"));
      return api.sendMessage(`📝 اختر الملف المراد تعديله بالرد على هذه الرسالة باسمه كاملاً:\n${D}\n${files.join("\n")}`, threadID, (err, info) => {
        global.client.handleReply.push({ name: this.config.name, author: senderID, messageID: info.messageID, type: "pick_edit" });
      }, messageID);
    }
    return startEdit(api, event, fileName, senderID);
  }

  // ── قسم عرض الملفات ──
  if (sub === "ملفات") {
    const files = fs.readdirSync(CMDS_PATH).filter(f => f.endsWith(".js"));
    return api.sendMessage(`📂 ملفات الأوامر (${files.length}):\n${D}\n${files.join("\n")}\n${D}\nلقراءة ملف: /نظام_وايد ملفات [الاسم]`, threadID, messageID);
  }

  // ── قسم إضافة أمر ──
  if (sub === "اضافة") {
    const cmdName = args[1];
    if (!cmdName) return api.sendMessage("❗ يجب تحديد اسم الأمر الجديد. مثال: /نظام_وايد اضافة test", threadID, messageID);
    return api.sendMessage(`⸙͎ إضافة أمر: ${cmdName}.js\n${D}\nأرسل الكود الآن كـرد على هذه الرسالة.`, threadID, (err, info) => {
      global.client.handleReply.push({ name: this.config.name, author: senderID, messageID: info.messageID, type: "new", cmdName });
    }, messageID);
  }

  // ── قسم تشغيل كود JS ──
  if (sub === "كود") {
    const code = args.slice(1).join(" ");
    if (!code) return api.sendMessage("💻 أرسل الكود الذي تريد تنفيذه كـرد.", threadID, (err, info) => {
      global.client.handleReply.push({ name: this.config.name, author: senderID, messageID: info.messageID, type: "eval" });
    }, messageID);
    return executeEval(api, event, code);
  }

  return api.sendMessage("❓ خيار غير موجود، استخدم القائمة الرئيسية.", threadID, messageID);
};

module.exports.handleReply = async function ({ api, event, handleReply }) {
  const { threadID, messageID, senderID, body } = event;
  if (String(senderID) !== String(handleReply.author)) return;

  // 1. معالجة اختيار ملف للتعديل
  if (handleReply.type === "pick_edit") {
    return startEdit(api, event, body.trim(), senderID);
  }

  // 2. معالجة حفظ الكود بعد التعديل
  if (handleReply.type === "write") {
    const fp = path.join(CMDS_PATH, handleReply.fileName);
    try {
      fs.writeFileSync(fp, body, "utf8");
      reloadCommand(fp, handleReply.fileName.replace(".js", ""));
      return api.sendMessage(`✅ تم تحديث الملف "${handleReply.fileName}" بنجاح!`, threadID, messageID);
    } catch (e) { return api.sendMessage(`❌ خطأ أثناء الحفظ: ${e.message}`, threadID, messageID); }
  }

  // 3. معالجة إضافة أمر جديد
  if (handleReply.type === "new") {
    const fp = path.join(CMDS_PATH, `${handleReply.cmdName}.js`);
    try {
      fs.writeFileSync(fp, body, "utf8");
      reloadCommand(fp, handleReply.cmdName);
      return api.sendMessage(`✅ تم إنشاء وتحميل الأمر "${handleReply.cmdName}"!`, threadID, messageID);
    } catch (e) { return api.sendMessage(`❌ فشل الإنشاء: ${e.message}`, threadID, messageID); }
  }

  // 4. معالجة الـ Eval
  if (handleReply.type === "eval") {
    return executeEval(api, event, body);
  }
};

// ── دالة مساعدة لبدء التعديل ──
function startEdit(api, event, fileName, senderID) {
  const fp = path.join(CMDS_PATH, fileName.endsWith(".js") ? fileName : fileName + ".js");
  if (!fs.existsSync(fp)) return api.sendMessage("❌ الملف غير موجود.", event.threadID, event.messageID);
  const content = fs.readFileSync(fp, "utf8");
  return api.sendMessage(`🜸 تعديل: ${fileName}\n${D}\n${content.slice(0, 2000)}\n${D}\nأرسل الكود الجديد كـرد.`, event.threadID, (err, info) => {
    global.client.handleReply.push({ name: "نظام_وايد", author: senderID, messageID: info.messageID, type: "write", fileName });
  }, event.messageID);
}

// ── دالة إعادة التحميل الفوري ──
function reloadCommand(fp, name) {
  delete require.cache[require.resolve(fp)];
  const newMod = require(fp);
  global.client.commands.set(name.toLowerCase(), newMod);
}

// ── دالة تنفيذ الأكواد ──
async function executeEval(api, event, code) {
  try {
    let result = await eval(code);
    api.sendMessage(`❥ نتيجة التنفيذ:\n${D}\n${JSON.stringify(result, null, 2)}\n${D}`, event.threadID, event.messageID);
  } catch (e) {
    api.sendMessage(`❌ خطأ في الكود:\n${e.message}`, event.threadID, event.messageID);
  }
}
